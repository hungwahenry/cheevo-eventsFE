# Base URL of the cheevo API — the client appends /api/v1, so do NOT include it here.
# Use Valet (cheevo.test) so HTTP Range works for video flyer playback.
#   iOS simulator:    http://cheevo.test
#   Android emulator: http://10.0.2.2  (proxy Valet via local LAN IP if testing video)
#   Physical device:  http://<your-mac-LAN-ip>   (e.g. http://192.168.1.20)
#   Production:       https://api.cheevo.app
EXPO_PUBLIC_API_URL=http://cheevo.test
