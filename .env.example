# Base URL of the cheevo API — the client appends /api/v1, so do NOT include it here.
#   iOS simulator:    http://127.0.0.1:8000
#   Android emulator: http://10.0.2.2:8000
#   Physical device:  http://<your-mac-LAN-ip>:8000   (e.g. http://192.168.1.20:8000)
#   Production:       https://api.cheevo.app
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
