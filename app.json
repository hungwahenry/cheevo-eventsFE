{
  "expo": {
    "name": "cheevo",
    "slug": "cheevo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cheevo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "events.cheevo.app",
      "associatedDomains": [
        "applinks:api.cheevo.vip",
        "applinks:cheevo.events",
        "applinks:api.cheevo.vip",
        "applinks:cheevo.events"
      ],
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "events.cheevo.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.cheevo.vip",
              "pathPrefix": "/payments/return"
            },
            {
              "scheme": "https",
              "host": "cheevo.events",
              "pathPrefix": "/events"
            },
            {
              "scheme": "https",
              "host": "cheevo.events",
              "pathPrefix": "/orders"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.cheevo.vip",
              "pathPrefix": "/payments/return"
            },
            {
              "scheme": "https",
              "host": "cheevo.events",
              "pathPrefix": "/events"
            },
            {
              "scheme": "https",
              "host": "cheevo.events",
              "pathPrefix": "/orders"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-web-browser",
      "expo-sharing",
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "cheevo needs calendar access to save events you're going to."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "organization": "issorite",
          "project": "cheevo-mobile"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11862163-606c-4190-a756-4617dccc0793"
      }
    },
    "owner": "henryhh",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/11862163-606c-4190-a756-4617dccc0793"
    }
  }
}
