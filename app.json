{
  "expo": {
    "name": "cheevo",
    "slug": "cheevo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cheevo",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "vip.cheevo.app",
      "associatedDomains": [
        "applinks:api.cheevo.vip",
        "applinks:cheevo.vip"
      ]
    },
    "android": {
      "package": "vip.cheevo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "api.cheevo.vip",
              "pathPrefix": "/payments/return"
            },
            {
              "scheme": "https",
              "host": "cheevo.vip",
              "pathPrefix": "/events"
            },
            {
              "scheme": "https",
              "host": "cheevo.vip",
              "pathPrefix": "/orders"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-image",
      "@react-native-community/datetimepicker",
      "expo-video",
      "expo-web-browser",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
